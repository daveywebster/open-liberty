<server description="com.ibm.ws.security.token.ltpa_fat.ltpaKeyPasswordTestServer">

    <featureManager>
        <feature>appSecurity-2.0</feature>
        <feature>jsp-2.3</feature>
    </featureManager>

    <include location="../fatTestPorts.xml" />

    <applicationManager autoExpand="true"/>

    <basicRegistry id="basic" realm="BasicRealm">
        <user name="user1" password="user1pwd" /> <!-- pragma: allowlist secret -->
    </basicRegistry>

    <application type="war" id="formlogin" name="formlogin" location="${server.config.dir}/apps/formlogin.war">
        <application-bnd>
            <security-role name="Employee">
                <user name="user1" />
            </security-role>
        </application-bnd>
    </application>

    <keyStore id="defaultKeyStore" password="{xor}EzY9Oi0rJg==" /> <!-- pragma: allowlist secret -->
    
</server>
